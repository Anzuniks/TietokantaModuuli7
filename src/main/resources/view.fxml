<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="SeiskaPisteKolme.ModuuliSeiskapisteKakkonenKopio.application.CurrencyController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Valuuttamuunnin" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10.0" alignment="CENTER">
        <TextField fx:id="amountField" promptText="Määrä" />
        <ComboBox fx:id="currencySelector" prefWidth="150.0" promptText="Valuutta" />
    </HBox>

    <Button text="Muunna" onAction="#handleConvert" />
    <Button text="Lisää valuutta" onAction="#handleAddCurrency" />

    <HBox spacing="10.0" alignment="CENTER">
        <Label text="Tulos:" />
        <Label fx:id="resultLabel" text="0.00" style="-fx-font-weight: bold;" />
    </HBox>

</VBox>